# Dummy, non-secret values for the automated test suite — safe to commit.
# Each test file starts its own mongodb-memory-server instance and connects
# to that directly (see tests/setup.ts); MONGODB_URI here only exists so
# config/env.ts's boot-time validation has something to parse.
NODE_ENV=test
PORT=4000

MONGODB_URI=mongodb://placeholder-overridden-by-test-setup/test
MONGODB_MAX_POOL_SIZE=5

JWT_SECRET=test-only-jwt-secret-not-used-in-production-32chars
JWT_EXPIRES_IN=1h

ADMIN_EMAIL=admin@turuq.test
# bcrypt hash of "TestPass123!", deliberately generated with a LOW cost
# factor (4, vs. the real app's 12 via `npm run hash-password`) — bcrypt's
# compare time is governed by the cost factor baked into the hash itself,
# not by any setting in the app code, so this is what keeps the test suite
# (which calls the real login endpoint, real bcrypt.compare, repeatedly —
# see auth.ratelimit.test.ts) fast and non-flaky regardless of the host
# machine's speed, without weakening anything about the real login flow.
ADMIN_PASSWORD_HASH=$2b$04$8qsg0uJX8nxxz6/LC04KKuNYmHpZYO4WH/Xm0.Y3RpNNTPj0nC4EO

CORS_ORIGIN=*

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
# Kept well above the 5 functional login calls auth.test.ts makes (rate-limit
# middleware state is a module-level singleton shared by every test *within*
# one file), but otherwise as low as practical: auth.ratelimit.test.ts (its
# own file, so this limiter starts fresh there) fires past this many
# requests on its own, and each attempt is a real bcrypt compare
# (intentionally slow, cost factor 12) — the lower this is, the fewer of
# those slow compares the rate-limit test needs before it can assert 429.
AUTH_RATE_LIMIT_MAX=10
