# Copy to .env and fill in real values. See README.md "Getting started".
NODE_ENV=development
PORT=4000

# Local dev without Docker/Atlas: run `npm run dev-mongo` in a separate
# terminal and paste the URI it prints here. For production, use a MongoDB
# Atlas connection string instead.
MONGODB_URI=mongodb://127.0.0.1:27017/turuq-backend
MONGODB_MAX_POOL_SIZE=10

# Optional: if your database password contains characters that would need
# percent-encoding in a URI (`:`, `/`, `@`, `%`, ...) — common with
# Atlas-autogenerated passwords — leave MONGODB_URI's userinfo out entirely
# (e.g. `mongodb+srv://cluster.mongodb.net/dbname?...`) and set these two
# instead. The driver uses them as-is, no URI encoding required.
# MONGODB_USER=
# MONGODB_PASSWORD=

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-random-32+-character-secret
JWT_EXPIRES_IN=1h

# The only "user" who can log in and obtain a token — see docs/ARCHITECTURE.md
# for why this is separate from the User Profile model the CRUD API manages.
ADMIN_EMAIL=admin@turuq.test
# Generate: npm run hash-password -- 'your-chosen-password'
ADMIN_PASSWORD_HASH=replace-with-a-bcrypt-hash

# Comma-separated list of allowed origins, or "*" for any (fine for this
# assessment; tighten to your actual frontend origin(s) in real production use).
CORS_ORIGIN=*

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
